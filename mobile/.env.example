# Copier vers .env pour le développement local (ne pas committer .env avec des secrets).
#
# Soit les noms Expo (recommandé) :
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL du site web (sans slash final) — ouvre les liens « événement » / « organisation » depuis l’app.
# EXPO_PUBLIC_WEB_APP_ORIGIN=https://ton-domaine.fr

# Google Maps (carte + géocodage) — même clé que le web si tu utilises déjà Maps / Geocoding API.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-key
#
# Soit les mêmes noms que le web à la racine (Vite) — pris en charge via app.config.js :
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-jwt

# Supabase Dashboard → Authentication → URL Configuration :
# ajouter la redirect URL générée par Expo, par ex. :
#   citizenvitae://
#   exp://127.0.0.1:8081/--/   (Expo Go, port variable)
